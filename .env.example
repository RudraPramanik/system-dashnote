# ── Existing ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dashnote:password@localhost:5432/dashnote
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Storage ───────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# ── AI Providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL=86400

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CHUNK_MIN_LENGTH=50

# ── Qdrant ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_NOTES_COLLECTION=notes_chunks
QDRANT_FILES_COLLECTION=files_chunks
QDRANT_TIMEOUT=30

# ── Neo4j (Phase 9 — leave blank) ────────────────────────────────────
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── LangSmith ─────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dashnote
LANGSMITH_TRACING_ENABLED=false

# ── ARQ Worker ────────────────────────────────────────────────────────
ARQ_REDIS_URL=redis://localhost:6379
WORKER_MAX_JOBS=5
WORKER_JOB_TIMEOUT=300

# ── Cost Controls ─────────────────────────────────────────────────────
TOKEN_BUDGET_PER_REQUEST=8000
